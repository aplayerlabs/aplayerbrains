#!/usr/bin/env bash
set -euo pipefail
shopt -s nocasematch 2>/dev/null || true

# A Player Brains — Setup Script
# Registers all brains as Claude Code slash commands via directory symlinks.
# Idempotent — safe to run multiple times.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
BRAINS_DIR="$SCRIPT_DIR/brains"
SKILLS_DIR="${HOME}/.claude/skills"

# The brains to register (order = chain sequence)
BRAINS=(
  aplayerbrains
  discover
  plan
  setup
  define
  design
  build
  test
  launch
  wrap
  status
  upgrade
)

echo ""
echo "  A Player Brains — Setup"
echo "  ======================="
echo ""

# --- Create directories if needed ---

if ! mkdir -p "$SKILLS_DIR" 2>/dev/null; then
  echo "  ERROR: Could not create $SKILLS_DIR — check permissions."
  exit 1
fi

# --- Cleanup old symlinks ---
# Remove any symlink in ~/.claude/skills/ that points into our repo.
# Catches both old "aplayerbrains-{name}" pattern and current "{name}" pattern.

echo "  Cleaning up old symlinks..."
CLEANED=0
for entry in "$SKILLS_DIR"/*/; do
  [ -d "$entry" ] || continue
  entry="${entry%/}"

  # Only touch symlinks (not real directories)
  if [ -L "$entry" ]; then
    target="$(readlink "$entry" 2>/dev/null || true)"
    # Check if this symlink points into our brains directory (nocasematch handles macOS)
    if [[ "$target" == "$BRAINS_DIR"* ]]; then
      rm "$entry"
      CLEANED=$((CLEANED + 1))
    fi
  fi
done

if [ "$CLEANED" -gt 0 ]; then
  echo "  Removed $CLEANED old symlink(s)."
else
  echo "  No old symlinks found."
fi
echo ""

# --- Create new symlinks ---
# Each brain directory is symlinked as:
#   ~/.claude/skills/{brain-name} → /path/to/repo/brains/{brain-name}
#
# This means ~/.claude/skills/discover/SKILL.md resolves correctly,
# AND relative paths inside SKILL.md (like "Read CLAUDE.md") resolve
# because CLAUDE.md lives in the same real directory.

echo "  Registering brains..."
echo ""
REGISTERED=0
FAILED=0

for brain in "${BRAINS[@]}"; do
  source_dir="$BRAINS_DIR/$brain"
  skill_file="$source_dir/SKILL.md"
  link_path="$SKILLS_DIR/$brain"

  if [ ! -d "$source_dir" ]; then
    echo "  SKIP  /$brain — directory not found: $source_dir"
    FAILED=$((FAILED + 1))
    continue
  fi

  if [ ! -f "$skill_file" ]; then
    echo "  SKIP  /$brain — no SKILL.md found"
    FAILED=$((FAILED + 1))
    continue
  fi

  # Remove stale link/dir if it exists (shouldn't after cleanup, but be safe)
  if [ -L "$link_path" ] || [ -e "$link_path" ]; then
    rm -rf "$link_path"
  fi

  if ln -s "$source_dir" "$link_path" 2>/dev/null; then
    echo "  OK    /$brain"
    REGISTERED=$((REGISTERED + 1))
  else
    echo "  FAIL  /$brain — could not create symlink (permissions?)"
    FAILED=$((FAILED + 1))
  fi
done

echo ""
echo "  ---"
echo "  Registered: $REGISTERED brain(s)"
if [ "$FAILED" -gt 0 ]; then
  echo "  Failed:     $FAILED brain(s)"
fi
echo ""

# --- Brain chain ---
echo "  Brain Chain"
echo "  ==========="
echo ""
echo "  /aplayerbrains  → Start here (routes to the right brain)"
echo "        │"
echo "  /discover        → Validate problem / refine idea"
echo "        │"
echo "  /plan            → Stress-test the direction"
echo "        │"
echo "  /setup           → GitHub + hosting"
echo "        │"
echo "  /define          → Product requirements"
echo "        │"
echo "  /design          → Visual design"
echo "        │"
echo "  /build           → Build the app"
echo "        │"
echo "  /test            → Find every bug"
echo "        │"
echo "  /launch          → Deploy and go live"
echo "        │"
echo "  /wrap            → Pause and resume later"
echo ""
echo "  Utilities:"
echo "  /status          → See where you are"
echo "  /upgrade         → Get the latest brains"
echo ""
echo "  Type /aplayerbrains in Claude Code to start."
echo ""
